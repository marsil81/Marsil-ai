# Marsil Backend Configuration
# Copy this file to .env and fill in your values.
# Environment variables override config.json — useful for keeping secrets out of version control.

MARSIL_API_KEY=sk-your-api-key-here
MARSIL_PROVIDER=deepseek
MARSIL_MODEL=deepseek-chat
MARSIL_BASE_URL=https://api.deepseek.com/v1
PORT=3001

# Security
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Logging (debug | info | warn | error)
LOG_LEVEL=info
